{
  "name": "fxxkjson",
  "version": "1.0.26",
  "description": "A desktop JSON formatting, repair, search, compare, and large-file inspection tool.",
  "author": "Alosan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aaronsound/FxxkJson.git"
  },
  "homepage": "https://github.com/Aaronsound/FxxkJson#readme",
  "bugs": {
    "url": "https://github.com/Aaronsound/FxxkJson/issues"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron ./dist-electron/main.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "check": "npm run check:text && npm run format:check && npm run lint && npm run typecheck && npm run coverage && npm run smoke && npm run build && npm run bundle:size",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "node ./scripts/bench-json.mjs",
    "bundle:size": "node ./scripts/report-bundle-size.mjs",
    "check:text": "node ./scripts/check-text-encoding.mjs",
    "perf:ci": "node ./scripts/perf-ci.mjs",
    "perf:regression": "node ./scripts/perf-regression.mjs",
    "setup:electron": "node ./scripts/ensure-electron-install.mjs",
    "smoke": "node ./scripts/smoke-json-flow.mjs",
    "e2e:electron": "npm run build && node ./scripts/e2e-electron-json-flow.mjs",
    "e2e:electron:large": "npm run build && node ./scripts/e2e-electron-json-flow.mjs --size-mb 5",
    "e2e:electron:large20": "npm run build && node ./scripts/e2e-electron-json-flow.mjs --size-mb 20",
    "release:assets:check": "node ./scripts/verify-release-assets.mjs",
    "samples": "node ./scripts/generate-json-samples.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:zip": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "jsonc-parser": "^3.3.1",
    "jsonrepair": "^3.14.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-split": "^2.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.aaronsound.fxxkjson",
    "productName": "FxxkJson",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "dist-electron/preload.js"
    ],
    "files": [
      "dist-renderer/**",
      "dist-electron/**",
      "build/icons/mac/icon.icns",
      "build/icons/win/icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "build/icons/win/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "mac": {
      "icon": "build/icons/mac/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
